{
  "name": "harness-creator",
  "version": "1.1.0",
  "description": "Create or adapt a coding-agent harness for either an existing repository or a new project, with support for spec-driven workflows, readiness gates, session continuity, and verification discipline.",
  "license": "MIT",
  "author": "Learn Harness Engineering",
  "repository": "https://github.com/walkinglabs/learn-harness-engineering",
  "languages": ["en"],
  "compatibility": {
    "minCliVersion": "0.1.0",
    "agents": [
      "claude-code",
      "codex-cli",
      "cursor",
      "windsurf",
      "generic"
    ]
  },
  "entryPoint": "SKILL.md",
  "references": [
    "references/repo-adaptation-pattern.md",
    "references/spec-driven-harness-pattern.md",
    "references/specs-directory-pattern.md",
    "references/docs-directory-pattern.md",
    "references/memory-persistence-pattern.md",
    "references/context-engineering-pattern.md",
    "references/tool-registry-pattern.md",
    "references/multi-agent-pattern.md",
    "references/lifecycle-bootstrap-pattern.md",
    "references/gotchas.md"
  ],
  "triggers": [
    "harness engineering",
    "agent reliability",
    "session continuity",
    "verification workflow",
    "AGENTS.md",
    "CLAUDE.md",
    "spec-driven development",
    "feature tracking",
    "progress tracking",
    "session handoff",
    "readiness gate",
    "existing harness",
    "greenfield harness",
    "agent scope control"
  ],
  "bundled": {
    "scripts": [
      "scripts/detect-harness.sh",
      "scripts/scaffold-greenfield.sh"
    ],
    "assets": [],
    "templates": [
      "templates/agents.md",
      "templates/specs-agents.md",
      "templates/docs-agents.md",
      "templates/feature-list.json",
      "templates/init.sh",
      "templates/progress.md",
      "templates/session-handoff.md",
      "templates/active-spec.md",
      "templates/docs-decision.md",
      "templates/docs-feature.md",
      "templates/docs-lesson.md",
      "templates/readiness-check.md"
    ]
  }
}
